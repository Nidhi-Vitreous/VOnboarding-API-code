{
  "_comment": "Copy to src/Api/appsettings.Development.json (gitignored) or use dotnet user-secrets / environment variables.",

  "Application": {
    "ApiRoutePrefix": "api/v1"
  },

  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=vonboarding_db;Username=postgres;Password=YOUR_POSTGRES_PASSWORD"
  },

  "Jwt": {
    "Issuer": "vitreous-onboarding",
    "Audience": "vitreous-onboarding-web",
    "Secret": "YOUR_LOCAL_JWT_SECRET_AT_LEAST_32_CHARACTERS_LONG",
    "AccessTokenTtlMinutes": 15,
    "RefreshTokenTtlDays": 7
  },

  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  },

  "Seed": {
    "Enabled": true,
    "AdminUsername": "admin",
    "AdminPassword": "ChangeMe123!"
  }
}
