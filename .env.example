# Backend environment variables (copy to .env for local tooling)
# Prefer user secrets or Azure Key Vault in real deployments.

ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vitreous_onboarding
DB_USER=
DB_PASSWORD=

# JWT (override in user secrets)
JWT_SECRET=
