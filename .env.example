# Backend environment variables (override appsettings at runtime)
# ASP.NET Core maps double-underscore env vars to nested configuration keys.

ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000

# Database
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=vonboarding_db;Username=postgres;Password=

# JWT (required — min 32 characters)
Jwt__Issuer=vitreous-onboarding
Jwt__Audience=vitreous-onboarding-web
Jwt__Secret=

# CORS (index array elements with __0, __1, ...)
Cors__AllowedOrigins__0=http://localhost:4200

# Optional dev-only admin seed (disabled in Production)
Seed__Enabled=true
Seed__AdminUsername=admin
Seed__AdminPassword=
